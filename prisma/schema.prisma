generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id           String   @id @default(uuid())
  licensePlate String   @unique
  brand        String
  model        String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
